# API
PORT=4000
CORS_ORIGIN=http://localhost:5174
JWT_SECRET=replace-with-a-long-random-secret

# MySQL / Prisma
DATABASE_URL="mysql://scenego:password@localhost:3306/scenego"

# OpenAI-compatible provider. Keep concrete provider settings outside app logic.
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
AI_MODEL=
AI_ENABLE_THINKING=
AI_THINKING_BUDGET=
AI_RESPONSE_FORMAT=
AI_MAX_TOKENS=
AI_CLASSIFICATION_MAX_TOKENS=512
AI_ANALYSIS_MAX_TOKENS=2048
AI_REQUEST_TIMEOUT_MS=

# OpenAI-compatible speech-to-text provider. Base URL and key fall back to the AI provider above.
STT_BASE_URL=
STT_API_KEY=
STT_MODEL=
STT_TRANSCRIPTION_PATH=/audio/transcriptions
STT_REQUEST_TIMEOUT_MS=120000
STT_MAX_AUDIO_BYTES=20971520
